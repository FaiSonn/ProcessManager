<Window x:Class="ProcessManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Process Manager"
        Height="650"
        Width="1000"
        Background="#f0f4f8">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ЗАГОЛОВОК -->
        <Border Grid.Row="0" Background="#1565c0" CornerRadius="6"
                Padding="16,10" Margin="0,0,0,10">
            <TextBlock Text="Process Manager"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"
                       FontFamily="Segoe UI"/>
        </Border>

        <!-- ВКЛАДКИ -->
        <TabControl Grid.Row="1" Background="White" BorderBrush="#bbdefb" BorderThickness="1">

            <TabItem Header="Список процессов" FontFamily="Segoe UI" FontSize="13">

                <DataGrid
                    ItemsSource="{Binding Processes}"
                    SelectedItem="{Binding SelectedProcess}"
                    AutoGenerateColumns="False"
                    Background="White"
                    RowBackground="White"
                    AlternatingRowBackground="#e3f2fd"
                    GridLinesVisibility="Horizontal"
                    HorizontalGridLinesBrush="#bbdefb"
                    BorderThickness="0"
                    CanUserAddRows="False"
                    CanUserResizeRows="False"
                    SelectionMode="Single"
                    FontFamily="Segoe UI"
                    FontSize="13">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1565c0"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderBrush" Value="#0d47a1"/>
                            <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="#212121"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1565c0"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#bbdefb"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="PID"        Binding="{Binding Id}"          Width="80"/>
                        <DataGridTextColumn Header="Имя"        Binding="{Binding Name}"        Width="*"/>
                        <DataGridTextColumn Header="Память МБ"  Binding="{Binding MemoryUsage}" Width="110"/>
                        <DataGridTextColumn Header="Потоки"     Binding="{Binding ThreadCount}" Width="80"/>
                        <DataGridTextColumn Header="Приоритет"  Binding="{Binding Priority}"   Width="120"/>
                    </DataGrid.Columns>

                </DataGrid>

            </TabItem>

            <TabItem Header="Дерево процессов" FontFamily="Segoe UI" FontSize="13">

                <TreeView ItemsSource="{Binding ProcessTree}"
                          Background="White"
                          BorderThickness="0"
                          FontFamily="Segoe UI"
                          FontSize="13">

                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Foreground" Value="#212121"/>
                            <Setter Property="Padding" Value="4,3"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1565c0"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#e3f2fd"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TreeView.ItemContainerStyle>

                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="2,2">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           MinWidth="200"/>
                                <TextBlock Text="PID: " Foreground="#1565c0" Margin="10,0,0,0"/>
                                <TextBlock Text="{Binding Id}" Foreground="#1565c0" MinWidth="50"/>
                                <TextBlock Text="Память: " Foreground="#1976d2" Margin="10,0,0,0"/>
                                <TextBlock Text="{Binding MemoryUsage}" Foreground="#1976d2"/>
                                <TextBlock Text=" МБ" Foreground="#1976d2"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>

                </TreeView>

            </TabItem>

        </TabControl>

        <!-- ПАНЕЛЬ УПРАВЛЕНИЯ -->
        <Border Grid.Row="2" Background="White" BorderBrush="#bbdefb"
                BorderThickness="1" CornerRadius="6"
                Padding="12" Margin="0,10,0,0">

            <StackPanel>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <Button Content="Завершить процесс"
                            Width="160" Height="32" Margin="5"
                            Background="#e53935" Foreground="White"
                            BorderThickness="0" FontFamily="Segoe UI"
                            FontSize="13" Cursor="Hand"
                            Click="Kill_Click"/>

                    <Button Content="Обновить"
                            Width="120" Height="32" Margin="5"
                            Background="#1565c0" Foreground="White"
                            BorderThickness="0" FontFamily="Segoe UI"
                            FontSize="13" Cursor="Hand"
                            Click="Refresh_Click"/>

                </StackPanel>

                <!-- Приоритет -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0">

                    <ComboBox x:Name="PriorityBox"
                              Width="150" Height="30" Margin="5"
                              FontFamily="Segoe UI" FontSize="13">
                        <ComboBoxItem Content="Idle"/>
                        <ComboBoxItem Content="BelowNormal"/>
                        <ComboBoxItem Content="Normal" IsSelected="True"/>
                        <ComboBoxItem Content="AboveNormal"/>
                        <ComboBoxItem Content="High"/>
                        <ComboBoxItem Content="RealTime"/>
                    </ComboBox>

                    <Button Content="Сменить приоритет"
                            Width="160" Height="30" Margin="5"
                            Background="#1565c0" Foreground="White"
                            BorderThickness="0" FontFamily="Segoe UI"
                            FontSize="13" Cursor="Hand"
                            Click="SetPriority_Click"/>

                </StackPanel>

                <!-- CPU Affinity -->
                <TextBlock Text="CPU Affinity"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,4"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           Foreground="#1565c0"
                           FontWeight="SemiBold"/>

                <ScrollViewer Height="60" HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <WrapPanel x:Name="CoresPanel" HorizontalAlignment="Center"/>
                </ScrollViewer>

                <Button Content="Применить Affinity"
                        Width="160" Height="30" Margin="0,8,0,0"
                        HorizontalAlignment="Center"
                        Background="#2e7d32" Foreground="White"
                        BorderThickness="0" FontFamily="Segoe UI"
                        FontSize="13" Cursor="Hand"
                        Click="SetAffinity_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>